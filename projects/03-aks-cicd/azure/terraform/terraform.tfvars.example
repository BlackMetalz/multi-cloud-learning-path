subscription_id = "your-azure-subscription-id"
project_name    = "gitops"
location        = "Southeast Asia"

# REQUIRED: GitHub repo in "owner/repo" format — used as OIDC subject.
# Must match the repo where the workflow runs.
github_repo        = "kienltqn/multi-cloud-learning-path"
github_main_branch = "main"

# Cost knobs
aks_node_count = 1
aks_node_size  = "Standard_D2s_v3"
